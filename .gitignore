# ── Production-Only Repo (.gitignore) ──────────────────────────────────────
# This repo is configured to only track files required for the website to run.

# Ignore Development Source & Config
src/
docs/
scripts/
package.json
package-lock.json
tsconfig.json
vite.config.ts
server.js
node_modules/
dist/
dist-ssr/
*.local

# Ignore OS & Editor Files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
logs/
*.log
